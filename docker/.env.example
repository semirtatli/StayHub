# =====================================================
# StayHub — Docker Compose Environment Variables
# =====================================================
# Copy this file to .env before running docker-compose.
# NEVER commit .env to source control (it's in .gitignore).
# This .env.example is committed as a reference.
# =====================================================

# SQL Server
MSSQL_SA_PASSWORD=YourStrong!Passw0rd
MSSQL_PID=Developer

# RabbitMQ
RABBITMQ_DEFAULT_USER=stayhub
RABBITMQ_DEFAULT_PASS=stayhub_dev_pass

# Seq (structured logging)
SEQ_FIRSTRUN_ADMINPASSWORDHASH=

# Ports (host:container) — change host ports if conflicts
SQL_SERVER_PORT=1433
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
SEQ_PORT=5341
SEQ_UI_PORT=8081
