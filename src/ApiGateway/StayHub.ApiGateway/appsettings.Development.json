{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Yarp": "Debug"
      }
    }
  },

  "RateLimiting": {
    "FixedWindow": {
      "PermitLimit": 1000,
      "WindowSeconds": 60
    },
    "SlidingWindow": {
      "PermitLimit": 200,
      "WindowSeconds": 60,
      "SegmentsPerWindow": 6
    }
  },

  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:3001", "http://localhost:5173" ]
  }
}
