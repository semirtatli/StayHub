{
  "ReverseProxy": {
    "Routes": {

      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },

      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        }
      },

      "identity-users-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },

      "hotels-route": {
        "ClusterId": "hotel-cluster",
        "Match": {
          "Path": "/api/hotels/{**catch-all}"
        }
      },

      "bookings-route": {
        "ClusterId": "booking-cluster",
        "Match": {
          "Path": "/api/bookings/{**catch-all}"
        }
      },

      "payments-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        }
      },

      "reviews-route": {
        "ClusterId": "review-cluster",
        "Match": {
          "Path": "/api/reviews/{**catch-all}"
        }
      },

      "notifications-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },

      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "Match": {
          "Path": "/api/analytics/{**catch-all}"
        }
      }
    },

    "Clusters": {

      "identity-cluster": {
        "Destinations": {
          "identity-primary": {
            "Address": "http://identity-api:8080"
          }
        }
      },

      "hotel-cluster": {
        "Destinations": {
          "hotel-primary": {
            "Address": "http://hotel-api:8080"
          }
        }
      },

      "booking-cluster": {
        "Destinations": {
          "booking-primary": {
            "Address": "http://booking-api:8080"
          }
        }
      },

      "payment-cluster": {
        "Destinations": {
          "payment-primary": {
            "Address": "http://payment-api:8080"
          }
        }
      },

      "review-cluster": {
        "Destinations": {
          "review-primary": {
            "Address": "http://review-api:8080"
          }
        }
      },

      "notification-cluster": {
        "Destinations": {
          "notification-primary": {
            "Address": "http://notification-api:8080"
          }
        }
      },

      "analytics-cluster": {
        "Destinations": {
          "analytics-primary": {
            "Address": "http://analytics-api:8080"
          }
        }
      }
    }
  }
}
